# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit your real credentials.

# Generated automatically on first install, or paste any 64-char random string.
# Example: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# YouTube OAuth credentials.
# 1. Create a Google Cloud project: https://console.cloud.google.com
# 2. Enable: YouTube Data API v3, YouTube Analytics API, YouTube Reporting API
# 3. OAuth consent screen → External, add channel emails as test users
# 4. Credentials → Create OAuth client → Web application
#    Authorized redirect URI: http://localhost:4007/integrations/social/youtube
# 5. Paste the Client ID and Client Secret here:
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Optional — only needed if you connect TikTok / Instagram / Facebook.
# TikTok requires Content Posting API approval from TikTok (3–14 days).
# Instagram + Facebook share Meta credentials; Instagram needs a Business
# account linked to a Facebook Page.
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Generated in Postiz UI: Settings → Developers → Public API → Create API Key
# The watcher uses this to upload media and create scheduled posts.
POSTIZ_API_KEY=
