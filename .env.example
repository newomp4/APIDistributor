# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit your real credentials.

# Post Bridge — the cloud scheduler that handles uploads to YouTube/TikTok/IG.
# Sign up: https://www.post-bridge.com  (Creator plan + $5/mo API add-on)
# Generate key at: https://www.post-bridge.com/dashboard/api-keys
POSTBRIDGE_API_KEY=

# Default base URL — only change if Post Bridge moves their API.
POSTBRIDGE_API_URL=https://api.post-bridge.com/v1
